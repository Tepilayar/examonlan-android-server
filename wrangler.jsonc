{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "examonlan-android-server",
  "compatibility_date": "2026-05-08",
  "pages_build_output_dir": ".",
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  }
}
